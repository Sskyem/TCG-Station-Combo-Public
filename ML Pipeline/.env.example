# Unity source project root. Used for Cards/Decks fallback, GameRulesConfig.json, and JSON patch sync.
TCG_GAME_ROOT=/absolute/path/to/TCG_Station

# Optional built game folder. On Windows this is the folder with the .exe.
# On macOS this is the folder containing TCG Station.app, not the .app bundle itself.
TCG_BUILD_ROOT=/absolute/path/to/Builds/macOS

# Optional direct overrides. These win over TCG_BUILD_ROOT.
TCG_LOGS_DIR=/absolute/path/to/Builds/macOS/Logs Export/ML
TCG_CARDS_DIR=/absolute/path/to/Builds/macOS/Cards
TCG_DECKS_DIR=/absolute/path/to/Builds/macOS/Decks

# Optional: prefill the "Sync ML logs mirror" fields with the logs-copy paths.
# Not required — you can type the paths in the dashboard instead. One path per device,
# separated by ';'. Point at any level (build root, the "Logs Export" or "Logs Export/ML"
# folder, or the "Decisions" folder itself); the subfolders are detected automatically.
# Windows example: \\HOST_A\share\…\TCG_Station\Logs Export\ML;\\HOST_B\share\…\Logs Export\ML
# macOS example: /Volumes/deviceA/…/Logs Export/ML;/Volumes/deviceB/…/Logs Export/ML
TCG_DECISIONS_MIRROR_DIR=/absolute/path/to/device1/logs-copy;/absolute/path/to/device2/logs-copy

# Optional private synchronization sources.
TCG_SMB_HOST=example.invalid
TCG_SMB_SHARE=tcg_station_logs
TCG_PROJECT_JSONS_SHORTCUT_ID=PUBLIC_PLACEHOLDER_CHANGE_ME
TCG_GOOGLE_DRIVE_ACCOUNT=account

